# Contracts environment — NEVER commit this file, it is in .gitignore

# Base Sepolia RPC (get a free key from Alchemy or Infura)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Your deployer wallet private key (export from MetaMask → Account Details)
# Fund this address with Base Sepolia ETH from: https://www.alchemy.com/faucets/base-sepolia
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Basescan API key for contract verification (https://basescan.org/myapikey)
BASESCAN_API_KEY=YOUR_BASESCAN_KEY_HERE
